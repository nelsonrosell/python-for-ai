# ===== PROD ENVIRONMENT =====
# Copy to .env.prod and fill in your values. Never commit .env.prod to git.
APP_ENV=prod

# ===== AZURE OPENAI =====
AZURE_OPENAI_API_KEY=your-prod-api-key
AZURE_OPENAI_ENDPOINT=https://your-prod-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ===== SQL DATABASE (FABRIC LAKEHOUSE - PRODUCTION) =====
SQL_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=tcp:your-prod-server.datawarehouse.fabric.microsoft.com,1433;Database=your_prod_database;Encrypt=yes;TrustServerCertificate=no;
# Leave SQL_ALLOWED_TABLES blank in dev to allow all tables, or provide a comma-separated allowlist., If later you want to limit dev to specific tables, set a comma-separated list like:
SQL_ALLOWED_TABLES=
SQL_USE_ACCESS_TOKEN_AUTH=true
SQL_ENTRA_LOGIN_HINT=your-prod-service-account@yourdomain.com

# ===== APP SECURITY / BEHAVIOR =====
# Required in non-dev unless trusted-header auth is configured at the proxy boundary.
APP_PASSWORD=replace-with-strong-secret
APP_ENABLE_VERBOSE_AGENT_LOGS=false
APP_MAX_EXPORT_ROWS=250

# Preferred for production behind an identity-aware proxy or gateway.
APP_TRUSTED_AUTH_HEADER=X-Forwarded-Authenticated
APP_TRUSTED_AUTH_VALUE=true
APP_TRUSTED_USER_HEADER=X-Authenticated-User
