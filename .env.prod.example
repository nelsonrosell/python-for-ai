# ===== PROD ENVIRONMENT =====
# Copy to .env.prod and fill in your values. Never commit .env.prod to git.
APP_ENV=prod

# ===== AZURE OPENAI =====
AZURE_OPENAI_API_KEY=your-prod-api-key
AZURE_OPENAI_ENDPOINT=https://your-prod-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ===== SQL DATABASE (FABRIC LAKEHOUSE - PRODUCTION) =====
SQL_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=tcp:your-prod-server.datawarehouse.fabric.microsoft.com,1433;Database=your_prod_database;Encrypt=yes;TrustServerCertificate=no;
SQL_USE_ACCESS_TOKEN_AUTH=true
SQL_ENTRA_LOGIN_HINT=your-prod-service-account@yourdomain.com
