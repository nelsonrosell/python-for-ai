# ===== DEV ENVIRONMENT =====
# Copy to .env.dev and fill in your values. Never commit .env.dev to git.
APP_ENV=dev

# ===== AZURE OPENAI =====
AZURE_OPENAI_API_KEY=your-dev-api-key
AZURE_OPENAI_ENDPOINT=https://your-dev-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ===== SQL DATABASE =====
# Point to a dev/local database or a dev Fabric workspace
# Leave SQL_ALLOWED_TABLES blank in dev to allow all tables, or provide a comma-separated allowlist., If later you want to limit dev to specific tables, set a comma-separated list like:
SQL_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=tcp:your-dev-server.datawarehouse.fabric.microsoft.com,1433;Database=your_dev_database;Encrypt=yes;TrustServerCertificate=no;
SQL_ALLOWED_TABLES=
SQL_USE_ACCESS_TOKEN_AUTH=true
SQL_ENTRA_LOGIN_HINT=your-email@yourdomain.com

# ===== APP SECURITY / BEHAVIOR =====
# Optional in dev; if unset, local dev can run without the login gate.
APP_PASSWORD=your-dev-password
APP_ENABLE_VERBOSE_AGENT_LOGS=false
APP_MAX_EXPORT_ROWS=500

# Optional trusted-header auth for local reverse-proxy setups.
APP_TRUSTED_AUTH_HEADER=
APP_TRUSTED_AUTH_VALUE=
APP_TRUSTED_USER_HEADER=
