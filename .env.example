# ===== SETUP INSTRUCTIONS =====
# 1. Copy this file to .env (do NOT commit .env to git - it contains secrets)
# 2. Fill in your own values for each variable below
# 3. Keep .env in .gitignore (already configured)
#
# ===== AZURE OPENAI =====
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ===== SQL DATABASE (FABRIC LAKEHOUSE) =====
# Connection string format (ODBC Driver 18 for SQL Server required)
SQL_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=tcp:your-server.datawarehouse.fabric.microsoft.com,1433;Database=your_database;Encrypt=yes;TrustServerCertificate=no;

# ===== ENTRA ID AUTHENTICATION (Token-based) =====
# Use token-based auth for Fabric Lakehouse + Azure Entra ID
# This is more reliable than connection string auth modes
SQL_USE_ACCESS_TOKEN_AUTH=true
# Optional: specify which Azure account to use for login (prevents wrong identity)
SQL_ENTRA_LOGIN_HINT=your-email@yourdomain.com
