# Copy this file to .env.dev or .env.prod and replace placeholder values.
# Choose exactly one auth mode for a real deployment:
#   1. Password auth: set APP_PASSWORD and leave trusted-header vars empty.
#   2. Trusted-header auth behind a real reverse proxy: set all trusted-header vars.

# -----------------------------------------------------------------------------
# Core environment
# -----------------------------------------------------------------------------
APP_ENV=dev
APP_ENABLE_VERBOSE_AGENT_LOGS=false
APP_MAX_EXPORT_ROWS=500

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
APP_LOG_LEVEL=WARNING
APP_LOG_FILE=logs/app.log
APP_LOG_MAX_BYTES=1048576
APP_LOG_BACKUP_COUNT=5

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Dev only. Keep false unless you explicitly want anonymous local access.
APP_ALLOW_ANONYMOUS_DEV_AUTH=false

# Password auth
# Set this for password-protected access. Leave empty if using trusted-header auth.
APP_PASSWORD=
APP_PASSWORD_MAX_ATTEMPTS=5
APP_PASSWORD_LOCKOUT_SECONDS=60
APP_AUTH_SESSION_TIMEOUT_SECONDS=1800

# Trusted-header auth
# For non-dev environments, APP_TRUSTED_AUTH_VALUE and APP_TRUSTED_USER_HEADER
# are required whenever APP_TRUSTED_AUTH_HEADER is set.
APP_TRUSTED_AUTH_HEADER=
APP_TRUSTED_AUTH_VALUE=
APP_TRUSTED_USER_HEADER=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Example SQLAlchemy URI:
# SQL_CONNECTION_STRING=mssql+pyodbc://user:pass@server/db?driver=ODBC+Driver+18+for+SQL+Server
# Example raw ODBC connection string:
# SQL_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=tcp:server.example.com,1433;Database=mydb;Encrypt=yes;TrustServerCertificate=no;
SQL_CONNECTION_STRING=

# Required outside dev. Comma-separated allowlist of tables/views the agent may query.
SQL_ALLOWED_TABLES=earthquake_events_gold

# Optional Entra token auth for SQL
SQL_USE_ACCESS_TOKEN_AUTH=false
SQL_ENTRA_LOGIN_HINT=

# -----------------------------------------------------------------------------
# Azure OpenAI
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=replace-me
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=replace-me