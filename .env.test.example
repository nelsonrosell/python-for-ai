# ===== TEST ENVIRONMENT =====
# Copy to .env.test and fill in your values. Never commit .env.test to git.
APP_ENV=test

# ===== AZURE OPENAI =====
AZURE_OPENAI_API_KEY=your-test-api-key
AZURE_OPENAI_ENDPOINT=https://your-test-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ===== SQL DATABASE =====
# Point to a test Fabric workspace or isolated test DB
SQL_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=tcp:your-test-server.datawarehouse.fabric.microsoft.com,1433;Database=your_test_database;Encrypt=yes;TrustServerCertificate=no;
# Leave SQL_ALLOWED_TABLES blank in dev to allow all tables, or provide a comma-separated allowlist., If later you want to limit dev to specific tables, set a comma-separated list like:
SQL_ALLOWED_TABLES=
SQL_ENTRA_LOGIN_HINT=your-email@yourdomain.com

# ===== APP SECURITY / BEHAVIOR =====
APP_PASSWORD=your-test-password
APP_ENABLE_VERBOSE_AGENT_LOGS=false
APP_MAX_EXPORT_ROWS=100

# Optional trusted-header auth for integration environments.
APP_TRUSTED_AUTH_HEADER=
APP_TRUSTED_AUTH_VALUE=
APP_TRUSTED_USER_HEADER=
