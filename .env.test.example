# ===== TEST ENVIRONMENT =====
# Copy to .env.test and fill in your values. Never commit .env.test to git.
APP_ENV=test

# ===== AZURE OPENAI =====
AZURE_OPENAI_API_KEY=your-test-api-key
AZURE_OPENAI_ENDPOINT=https://your-test-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ===== SQL DATABASE =====
# Point to a test Fabric workspace or isolated test DB
SQL_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=tcp:your-test-server.datawarehouse.fabric.microsoft.com,1433;Database=your_test_database;Encrypt=yes;TrustServerCertificate=no;
SQL_USE_ACCESS_TOKEN_AUTH=true
SQL_ENTRA_LOGIN_HINT=your-email@yourdomain.com
